#
# Copy this file to android/key.properties (already in .gitignore)
# and fill in the real values for your keystore.
#
# Generate the keystore once:
#   keytool -genkey -v \
#     -keystore android/app/gambit-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias gambit \
